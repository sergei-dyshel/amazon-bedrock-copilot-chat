{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "npm",
			"script": "watch",
			"group": "build",
			"problemMatcher": [
				"$tsc-watch",
			],
			"isBackground": true,
      "runOptions": {
        "runOn": "folderOpen"
      },
			"presentation": {
				"reveal": "never",
				"group": "watchers"
			},
			"label": "npm: watch"
		},
		{
			"type": "npm",
			"script": "compile",
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": ["$tsc"],
			"label": "npm: compile"
		},
		{
			"type": "npm",
			"script": "package",
			"group": "build",
			"problemMatcher": ["$tsc"],
			"label": "npm: package - production build"
		},
		{
			"type": "npm",
			"script": "lint",
			"problemMatcher": "$eslint-stylish",
			"label": "npm: lint"
		}
	]
}
